{
  "name": "altair-vega-web",
  "version": "0.9.0-RC2",
  "private": true,
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EL-File4138/Altair-Vega.git",
    "directory": "web/frontend"
  },
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:no-worker": "node scripts/dev.mjs --no-worker",
    "dev:vite": "vite",
    "build": "tsc -b --force && vite build --base='./'",
    "preview": "vite preview",
    "build:wasm": "wasm-pack build ../browser-wasm --dev --weak-refs --reference-types -t bundler -d ../frontend/pkg",
    "build:wasm:release": "wasm-pack build ../browser-wasm --release --weak-refs --reference-types -t bundler -d ../frontend/pkg"
  },
  "dependencies": {
    "altair-vega-browser": "file:./pkg",
    "dompurify": "^3.3.0",
    "lucide-solid": "^1.14.0",
    "marked": "^17.0.1",
    "qrcode-generator": "^2.0.4",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vite-plugin-solid": "^2.11.12",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "ws": "^8.18.3"
  }
}
